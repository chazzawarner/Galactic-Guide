# Local overrides — copy this file to .env and adjust as needed.
# .env is gitignored; this file is committed.

POSTGRES_USER=galactic
POSTGRES_PASSWORD=changeme
POSTGRES_DB=galactic_guide
DATABASE_URL=postgresql+asyncpg://galactic:changeme@postgres:5432/galactic_guide
REDIS_URL=redis://redis:6379/0

# Set to 1 to force use of the committed TLE fallback snapshot (no CelesTrak fetch).
OFFLINE=0

# Number of proptest cases to run per property (lower for faster CI; raise for thoroughness).
PROPTEST_CASES=64

# Internal URL used by the web container to reach the API container.
# In Docker Compose this resolves via the internal Docker network.
# When running outside Docker, set this to http://localhost:8000.
API_INTERNAL_URL=http://api:8000
